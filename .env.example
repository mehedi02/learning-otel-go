PORT=5000

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=user_service

REDIS_HOST=localhost
REDIS_PORT=6379

# OpenTelemetry
# Trace endpoint format is host:port (no scheme). Used for OTLP/gRPC export to Tempo.
OTEL_EXPORTER_OTLP_ENDPOINT=localhost:4317
# Metrics endpoint is host:port (no scheme). Sent via OTLP/HTTP to Prometheus
# at the fixed path /api/v1/otlp/v1/metrics. Prometheus must be started with
# --web.enable-otlp-receiver (Prometheus 2.55+).
OTEL_EXPORTER_OTLP_METRICS_ENDPOINT=localhost:9090
OTEL_SERVICE_NAME=user-service
OTEL_SERVICE_VERSION=0.1.0
OTEL_SERVICE_ENVIRONMENT=development
# 1.0 = sample 100% of traces (dev). Lower in production, e.g. 0.1.
OTEL_TRACE_SAMPLE_RATIO=1.0
# How often the periodic metric reader ships metrics to the collector.
OTEL_METRICS_EXPORT_INTERVAL_SEC=15
